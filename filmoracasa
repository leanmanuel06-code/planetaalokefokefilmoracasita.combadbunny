<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LA CASA DE FILMORA</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
scroll-behavior:smooth;
}

body{
background:linear-gradient(to bottom,#000,#111);
color:white;
}

header{
background:#0d0d0d;
padding:20px 40px;
display:flex;
justify-content:space-between;
align-items:center;
border-bottom:2px solid red;
position:sticky;
top:0;
z-index:1000;
}

.logo{
display:flex;
align-items:center;
gap:15px;
}

.house{
width:60px;
height:60px;
background:#1a1a1a;
transform:rotate(45deg);
border-radius:10px;
position:relative;
}

.house::before{
content:"";
position:absolute;
width:80px;
height:20px;
background:red;
top:-18px;
left:-10px;
transform:rotate(-45deg);
border-radius:10px;
}

.logo-text{
font-size:28px;
font-weight:bold;
}

.logo-text span{
color:red;
}

nav{
display:flex;
flex-wrap:wrap;
justify-content:center;
}

nav a{
color:white;
text-decoration:none;
margin:10px;
transition:0.3s;
font-weight:bold;
}

nav a:hover{
color:red;
}

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:20px;
background:radial-gradient(circle,#1a0000,#000);
}

.hero h1{
font-size:65px;
margin-bottom:20px;
}

.hero h1 span{
color:red;
}

.hero p{
max-width:900px;
font-size:22px;
line-height:1.7;
color:#ccc;
margin-bottom:30px;
}

.btn{
padding:15px 40px;
background:red;
color:white;
border:none;
border-radius:10px;
font-size:20px;
cursor:pointer;
transition:0.3s;
font-weight:bold;
}

.btn:hover{
background:darkred;
transform:scale(1.05);
box-shadow:0 0 20px red;
}

.section{
padding:80px 40px;
text-align:center;
background:#111;
border-bottom:1px solid #222;
}

.section h2{
font-size:45px;
margin-bottom:25px;
color:red;
}

.section p{
max-width:950px;
margin:auto;
font-size:21px;
line-height:1.9;
color:#d0d0d0;
}

.media{
margin-top:30px;
width:90%;
max-width:1000px;
border-radius:20px;
border:2px solid red;
box-shadow:0 0 25px rgba(255,0,0,0.7);
}

footer{
background:#000;
padding:20px;
text-align:center;
color:#888;
border-top:2px solid red;
}

@media(max-width:768px){

header{
flex-direction:column;
gap:15px;
}

.hero h1{
font-size:42px;
}

.hero p{
font-size:18px;
}

.section h2{
font-size:34px;
}

.section p{
font-size:18px;
}

iframe{
height:250px;
}
}
</style>
</head>

